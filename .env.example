# Zero-config local dev does not require a .env file.
# Copy this file to .env only when you want MySQL-backed persistence or to override runtime defaults.
# Keep credentials in a secret store for shared environments. If you use local env-backed secrets for
# isolated development, export them manually instead of committing them here.

# Optional MySQL persistence.
VEIL_MYSQL_HOST=127.0.0.1
VEIL_MYSQL_PORT=3306
VEIL_MYSQL_USER=root
VEIL_MYSQL_DATABASE=project_veil
VEIL_MYSQL_SNAPSHOT_TTL_HOURS=72
VEIL_MYSQL_SNAPSHOT_CLEANUP_INTERVAL_MINUTES=30

# Optional managed secret bootstrap.
VEIL_SECRET_PROVIDER=env
# VEIL_AWS_SECRETS_MANAGER_SECRET_ID=projectveil/dev/server
# VEIL_AWS_SECRETS_MANAGER_REGION=us-east-1

# Optional MySQL backup to S3-compatible object storage.
VEIL_BACKUP_S3_BUCKET=
VEIL_BACKUP_S3_PREFIX=backups/mysql
VEIL_BACKUP_S3_ENDPOINT=
VEIL_BACKUP_S3_REGION=us-east-1
VEIL_BACKUP_AWS_PROFILE=
VEIL_BACKUP_KEEP_DAILY_DAYS=30
VEIL_BACKUP_KEEP_WEEKLY_DAYS=183
VEIL_BACKUP_WEEKLY_DAY=7
# Example notify hook:
# VEIL_BACKUP_NOTIFY_COMMAND=curl -fsS -X POST https://hooks.example.test/project-veil -d "message=$VEIL_BACKUP_FAILURE_MESSAGE"

# Optional observability integrations.
# Keep ANALYTICS_SINK=stdout for local smoke. Switch to http only when you also provide ANALYTICS_ENDPOINT.
ANALYTICS_SINK=stdout
# ANALYTICS_ENDPOINT=https://analytics.projectveil.example/ingest
ANALYTICS_WAREHOUSE_DATASET=analytics_prod
ANALYTICS_WAREHOUSE_EVENTS_TABLE=veil_analytics_events
ANALYTICS_RAW_BUCKET=s3://project-veil-analytics-prod/raw
ANALYTICS_RETENTION_DAYS=400
ANALYTICS_DELETION_WORKFLOW=dsr-player-delete
# Set a real DSN to smoke-test external error delivery; leaving this unset keeps runtime diagnostics local-only.
# SENTRY_DSN=https://public@example.ingest.sentry.io/42

# Optional auth/runtime overrides.
VEIL_RATE_LIMIT_AUTH_WINDOW_MS=60000
VEIL_RATE_LIMIT_AUTH_MAX=10
VEIL_RATE_LIMIT_WS_ACTION_WINDOW_MS=1000
VEIL_RATE_LIMIT_WS_ACTION_MAX=8
VEIL_AUTH_LOCKOUT_THRESHOLD=10
VEIL_AUTH_LOCKOUT_DURATION_MINUTES=15
VEIL_MAX_GUEST_SESSIONS=10000
VEIL_AUTH_ACCESS_TTL_SECONDS=3600
VEIL_AUTH_REFRESH_TTL_SECONDS=2592000
VEIL_AUTH_GUEST_TTL_SECONDS=604800
VEIL_MATCHMAKING_QUEUE_TTL_SECONDS=300
