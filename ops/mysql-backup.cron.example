MAILTO=ops@example.com
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Daily backup at 03:00 server local time.
# The script itself mirrors Sunday backups into weekly/ and prunes daily>30d, weekly>183d.
0 3 * * * cd /srv/ProjectVeil && /usr/bin/env bash ./scripts/db-backup.sh >> /var/log/project-veil/db-backup.log 2>&1
