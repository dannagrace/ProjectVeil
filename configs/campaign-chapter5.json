{
  "missions": [
    {
      "id": "chapter5-crownless-watch",
      "chapterId": "chapter5",
      "order": 28,
      "mapId": "frontier-basin",
      "name": "Crownless Watch",
      "description": "Push beyond the shattered throne and secure the watch posts where loyalist officers are trying to re-form the court.",
