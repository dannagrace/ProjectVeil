          "description": "Clear the skeletal curators guarding the archive road",
          "kind": "defeat",
          "gate": "mid"
        }
      ],
      "reward": { "gems": 84, "resources": { "gold": 1440, "wood": 28, "ore": 62 } }
    },
    {
