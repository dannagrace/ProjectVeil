    {
      "id": "chapter6-new-banner",
      "chapterId": "chapter6",
      "order": 40,
      "mapId": "stonewatch-fork",
      "name": "New Banner",
      "description": "Hold the liberated fork long enough to raise the frontier banner before the last archive legions can retake the road.",
