          "mood": "grim"
        }
      ],
      "objectives": [
        {
          "id": "c1m1-clear-patrol",
          "description": "Break the screening patrol",
          "kind": "defeat",
          "gate": "start"
        },
        {
          "id": "c1m1-secure-flare",
          "description": "Secure the signal flare cache",
          "kind": "secure",
          "gate": "end",
          "optional": true
        }
      ],
      "reward": { "gems": 12, "resources": { "gold": 140 } }
    },
