{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "configs/schemas/season-rewards.schema.json",
  "title": "Season Reward Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["brackets"],
  "properties": {
    "brackets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topPercentile", "gems", "badge"],
        "properties": {
          "topPercentile": {
            "type": "number",
            "exclusiveMinimum": 0,
            "maximum": 100
          },
          "gems": {
            "type": "integer",
            "minimum": 0
          },
          "badge": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
