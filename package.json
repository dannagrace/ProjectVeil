{
  "name": "project-veil",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "node --import tsx ./scripts/ops/dev-cli.ts",
    "build:server": "npm run validate -- season-reward-config && node ./scripts/build-server.mjs",
    "client:primary": "node --eval \"console.log('Primary runtime: open apps/cocos-client in Cocos Creator 3.8.x and preview the VeilRoot scene. H5 debug shell: npm run dev -- client:h5')\"",
    "build:client": "npm run build:client:h5",
    "build:client:h5": "vite build --config apps/client/vite.config.ts",
    "db": "node --import tsx ./scripts/ops/db-cli.ts",
    "player-names:scan": "node --import tsx ./scripts/scan-player-display-names.ts",
    "config-center:restore": "node --import tsx ./scripts/config-center-restore.ts",
    "ops:branch-hygiene": "node --import tsx ./scripts/audit-codex-automation-branches.ts",
    "ops:codex-branches": "npm run ops:branch-hygiene --",
    "ops:run-watchdog": "node --import tsx ./scripts/run-watchdog.ts",
    "plan:validation:minimal": "node --import tsx ./scripts/minimal-validation-plan.ts",
    "docs:command-index": "node --import tsx ./scripts/ops/command-index.ts",
    "docs:release-script-inventory": "node --import tsx ./scripts/release-script-inventory.ts",
    "docs:release-ops-ownership-matrix": "node --import tsx ./scripts/release-ops-ownership-matrix.ts",
    "demo:flow": "node --import tsx ./scripts/demo.ts",
    "preview:daily-quest-rotation": "node --import tsx ./scripts/daily-quest-rotation-preview.ts",
    "doctor": "node ./scripts/repo-doctor.mjs",
    "release": "node --import tsx ./scripts/release/cli.ts",
    "validate": "node --import tsx ./scripts/validate/cli.ts",
    "experiment:metrics-rollup": "node --import tsx ./scripts/experiment-metrics-rollup.ts",
    "analytics:onboarding:funnel": "node --import tsx ./scripts/onboarding-funnel-report.ts",
    "smoke": "node --import tsx ./scripts/smoke/cli.ts",
    "stress:rooms": "node --import tsx ./scripts/stress-concurrent-rooms.ts",
    "stress:rooms:baseline": "node --import tsx ./scripts/stress-concurrent-rooms.ts --rooms=48 --connect-concurrency=12 --action-concurrency=12 --sample-interval-ms=100 --reconnect-pause-ms=150 --artifact-path=artifacts/release-readiness/stress-rooms-runtime-metrics.json",
    "stress:rooms:capacity-plan": "node --import tsx ./scripts/capacity-planning-report.ts",
    "ops:hpa-scale-drill": "node --import tsx ./scripts/hpa-scale-drill.ts",
    "stress:rooms:reconnect-soak": "node --import tsx ./scripts/stress-concurrent-rooms.ts --scenarios=reconnect_soak --rooms=48 --connect-concurrency=12 --action-concurrency=12 --sample-interval-ms=100 --reconnect-pause-ms=150 --reconnect-cycles=8",
    "perf:runtime:compare": "node --import tsx ./scripts/compare-runtime-regression.ts --baseline ./configs/runtime-regression-baseline.json --artifact ./artifacts/release-readiness/stress-rooms-runtime-metrics.json --output ./artifacts/release-readiness/runtime-regression-report.json",
    "sync:assets:pixel": "node ./scripts/sync-h5-pixel-assets.mjs",
    "sync:assets:audio": "node ./scripts/sync-cocos-audio-assets.mjs",
    "prepare:wechat-build": "node --import tsx ./scripts/prepare-wechat-minigame-build.ts",
    "prepare:wechat-release": "node --import tsx ./scripts/prepare-wechat-minigame-release.ts",
    "package:wechat-release": "node --import tsx ./scripts/package-wechat-minigame-release.ts",
    "upload:wechat-release": "node --import tsx ./scripts/upload-wechat-minigame-release.ts",
    "download:wechat-release": "node --import tsx ./scripts/download-wechat-minigame-artifact.ts",
    "verify:wechat-release": "node --import tsx ./scripts/verify-wechat-minigame-artifact.ts",
    "ingest:wechat-smoke-evidence": "node --import tsx ./scripts/smoke-wechat-minigame-release.ts",
    "ci:trend-summary": "node --import tsx ./scripts/publish-ci-trend-summary.ts",
    "audit:cocos-primary-delivery": "node --import tsx ./scripts/audit-cocos-primary-delivery.ts",
    "check:wechat-build": "node --import tsx ./scripts/prepare-wechat-minigame-build.ts --check && node --import tsx ./scripts/validate-wechat-minigame-build.ts --output-dir apps/cocos-client/build-templates/wechatgame && node --import tsx ./scripts/validate-wechat-minigame-build.ts --output-dir apps/cocos-client/test/fixtures/wechatgame-export --expect-exported-runtime && node --import tsx ./scripts/prepare-wechat-minigame-release.ts --output-dir apps/cocos-client/test/fixtures/wechatgame-export --expect-exported-runtime --check",
    "check:cocos-release-readiness": "node --import tsx ./scripts/validate-assets.ts --require-cocos-release-ready && npm run check:wechat-build",
    "sync:assets:h5-pixel": "npm run sync:assets:pixel",
    "check:issue33-assets": "node ./scripts/check-issue-33-art-staging.mjs",
    "test": "node --import tsx ./scripts/test-harness/cli.ts",
    "lint:cocos:panels": "node ./scripts/check-cocos-panel-boundaries.mjs && node ./scripts/audit-cocos-panel-view-models.mjs",
    "lint:arch": "node ./scripts/check-shared-import-boundaries.mjs && node ./scripts/check-project-shared-parity.mjs && npm run lint:cocos:panels && depcruise --config .dependency-cruiser.cjs apps packages/shared scripts tests",
    "lint:arch:report": "depcruise --config .dependency-cruiser.cjs --output-type err apps packages/shared scripts tests",
    "generate:cocos:panel": "node --import tsx ./scripts/generate-cocos-panel.ts",
    "typecheck": "node --import tsx ./scripts/ops/typecheck-cli.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "dependency-cruiser": "17.3.10",
    "esbuild": "^0.25.12",
    "ioredis-mock": "^8.13.1",
    "miniprogram-ci": "^2.1.31",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.4.1",
    "ws": "^8.18.3"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1041.0",
    "@colyseus/redis-driver": "^0.17.7",
    "@colyseus/redis-presence": "^0.17.7",
    "@colyseus/sdk": "^0.17.42",
    "@veil/shared": "file:packages/shared",
    "cc": "file:packages/cc-runtime-stub",
    "colyseus": "^0.17.10",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "mysql2": "^3.22.3",
    "xlsx": "^0.18.5"
  }
}
